APP_NAME="Clinica Financeiro API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.papalino.com.br
FRONTEND_URL=https://app.papalino.com.br

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=clinica_financeiro
DB_USERNAME=clinica_user
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@papalino.com.br
MAIL_FROM_NAME="MedIntelligence"

AI_CHAT_PROVIDER=langchain
AI_CHAT_TIMEOUT=120
AI_CHAT_FILE_TIMEOUT=600

CHATBOT_RUNTIME_DRIVER=langchain
CHATBOT_RUNTIME_URL=http://langchain-runtime:8787
CHATBOT_RUNTIME_SECRET=
CHATBOT_RUNTIME_HISTORY_LIMIT=20
CHATBOT_RAG_SEARCH_LIMIT=8
CHATBOT_RAG_MAX_CHUNK_LENGTH=8000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
OPENAI_AUDIO_TRANSCRIPTIONS_URL=https://api.openai.com/v1/audio/transcriptions
OPENAI_TIMEOUT=120

LANGCHAIN_CHAT_URL=http://langchain-runtime:8787/chat
LANGCHAIN_FILE_URL=http://langchain-runtime:8787/chat/file
LANGCHAIN_API_KEY=

N8N_WEBHOOK_CHAT_URL=https://n8n-n8n-start.aeuv6j.easypanel.host/webhook/medintelligence_chatbot_ia
N8N_WEBHOOK_URL=https://n8n-n8n-start.aeuv6j.easypanel.host/webhook/medintelligence_parser_fatura
N8N_WEBHOOK_TOKEN=
N8N_INGEST_SECRET=

CHATBOT_CHAT_UPLOAD_MIRROR_TO_DRIVE=true
CHATBOT_CHAT_UPLOAD_MIRROR_TO_DRIVE_REQUIRED=false
CHATBOT_CHAT_UPLOAD_DRIVE_NAME_PREFIX=chat-upload
CHATBOT_CHAT_UPLOAD_INDEX_TO_RAG=true

GOOGLE_DRIVE_OAUTH_ACCESS_TOKEN=
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_OAUTH_TOKEN_CACHE_PREFIX=google_drive_oauth_access_token
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SERVICE_ACCOUNT_PATH=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive
GOOGLE_DRIVE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_DRIVE_FILES_URL=https://www.googleapis.com/drive/v3/files
GOOGLE_DRIVE_UPLOAD_BASE_URL=https://www.googleapis.com/upload/drive/v3/files
GOOGLE_DRIVE_TIMEOUT=30

CNPJA_API_KEY=
CNPJA_BASE_URL=https://api.cnpja.com
CNPJA_PUBLIC_BASE_URL=https://open.cnpja.com
CNPJA_TIMEOUT=15
CNPJA_STRATEGY=CACHE_IF_ERROR
CNPJA_MAX_AGE=7
CNPJA_MAX_STALE=30
CNPJA_INCLUDE_SIMPLES=true

CPF_CNPJ_API_KEY=
CPF_CNPJ_BASE_URL=https://api.cpfcnpj.com.br
CPF_CNPJ_TIMEOUT=60

VIACEP_BASE_URL=https://viacep.com.br/ws
VIACEP_TIMEOUT=10
